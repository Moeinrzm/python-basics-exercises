#Password Generator with using random and string 
import string
import random

def password_generator(length=10):
    allowed_punctuation="@!#$%"
    chars=string.ascii_letters+string.digits+allowed_punctuation
    password="".join(random.choice(chars) for _ in range(length))

    return password
while True:
    val=input("enter the length password")
    try:
        val=int(val)
        if val<=0 :
            print("please enter a positive number!")
            continue
        password=password_generator(val)
        print(f"your password:{password}")
        break
    except ValueError:
        print("enter a number please!!!")

